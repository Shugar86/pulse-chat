# Backend
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulsechat?schema=public

JWT_ACCESS_SECRET=replace-me-in-production-min-32-chars
JWT_REFRESH_SECRET=replace-me-in-production-min-32-chars

# Client (Expo)
EXPO_PUBLIC_API_URL=http://localhost:4000

# Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pulsechat
