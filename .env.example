# Backend
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulsechat?schema=public

# API
JWT_ACCESS_SECRET=replace-me-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-me-with-at-least-32-characters
CORS_ORIGIN=http://localhost:8081

# Client (Expo)
EXPO_PUBLIC_API_URL=http://localhost:4000

# Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pulsechat

# VPN
WG_HOST=vpn.localhost
WG_PASSWORD=changeme
WG_PORT=51820
WG_DNS=1.1.1.1
WG_ALLOWED_IPS=0.0.0.0/0, ::/0
WG_SYNC_DIR=./.wg-sync

# API-facing VPN config (server public key comes from wg-easy after first start)
WG_SERVER_PUBLIC_KEY=
WG_ENDPOINT=vpn.localhost:51820
WG_NETWORK=10.200.0.0/24

# Redis
REDIS_URL=redis://localhost:6379

# TURN
TURN_SECRET=change-me-turn-secret
TURN_HOST=turn.pulse.chat

# Domains
API_DOMAIN=api.pulse.chat
VPN_DOMAIN=vpn.pulse.chat
TURN_DOMAIN=turn.pulse.chat
